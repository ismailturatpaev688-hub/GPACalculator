<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.AboutPage"
             x:DataType="viewModels:AboutViewModel"
             BackgroundColor="#F5F5F5"
             Title="О программе">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <Label Text="О программе" 
                   FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"
                   TextColor="#2C3E50" Margin="0,10,0,20"/>

            <!-- Иконка приложения -->
            <Border Stroke="#3498DB" StrokeShape="Ellipse" WidthRequest="100" HeightRequest="100" BackgroundColor="#EBF5FB" HorizontalOptions="Center" Margin="0,0,0,20">
                <Label Text="🎓" FontSize="50" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Border Stroke="#E0E0E0" StrokeShape="RoundRectangle 15" Padding="20" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Калькулятор GPA" FontSize="24" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>
                    <Label Text="{Binding AppVersion, StringFormat='Версия: {0}'}" FontSize="16" TextColor="#7F8C8D" HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" Color="#ECF0F1" Margin="0,10"/>

                    <Label Text="Описание" FontSize="18" FontAttributes="Bold" TextColor="#3498DB" HorizontalOptions="Center"/>
                    <Label Text="{Binding Description}" FontSize="15" TextColor="#2C3E50" LineBreakMode="WordWrap" HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" Color="#ECF0F1" Margin="0,10"/>

                    <Label Text="Разработчики" FontSize="18" FontAttributes="Bold" TextColor="#3498DB" HorizontalOptions="Center"/>
                    <Label Text="{Binding Developers}" FontSize="16" TextColor="#2C3E50" HorizontalOptions="Center"/>
                    <Label Text="{Binding Group, StringFormat='Учебная группа: {0}'}" FontSize="16" TextColor="#7F8C8D" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>