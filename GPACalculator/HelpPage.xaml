<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.HelpPage"
             x:DataType="viewModels:HelpViewModel"
             BackgroundColor="#F5F5F5"
             Title="Помощь">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <!-- Заголовок -->
            <Label Text="Помощь и инструкция" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"
                   Margin="0,10,0,20"/>

            <!-- Что такое GPA -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Что такое GPA?" 
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#3498DB"/>

                    <Label Text="GPA (Grade Point Average) — это средний балл ваших оценок. Он рассчитывается с учетом веса (кредитов) каждого предмета." 
                           FontSize="15"
                           TextColor="#2C3E50"
                           LineBreakMode="WordWrap"/>

                    <Border Stroke="#27AE60"
                            StrokeShape="RoundRectangle 10"
                            Padding="15"
                            BackgroundColor="#EAFAF1">
                        <Label Text="Пример: Если у вас 2 предмета (Математика - вес 5, оценка 4 и Физика - вес 3, оценка 5), то GPA = (4×5 + 5×3) / (5+3) = 35/8 = 4.38" 
                               FontSize="14"
                               TextColor="#27AE60"
                               LineBreakMode="WordWrap"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Как пользоваться -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Как пользоваться приложением?" 
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#3498DB"/>

                    <!-- Шаг 1 -->
                    <HorizontalStackLayout Spacing="15">
                        <Border Stroke="#9B59B6"
                                StrokeShape="RoundRectangle 50"
                                WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#9B59B6">
                            <Label Text="1"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="На главной странице добавьте предметы: введите название, оценку (2-5) и вес предмета" 
                               FontSize="15"
                               TextColor="#2C3E50"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"/>
                    </HorizontalStackLayout>

                    <!-- Шаг 2 -->
                    <HorizontalStackLayout Spacing="15">
                        <Border Stroke="#9B59B6"
                                StrokeShape="RoundRectangle 50"
                                WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#9B59B6">
                            <Label Text="2"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Нажмите «Рассчитать GPA» чтобы увидеть ваш средний балл" 
                               FontSize="15"
                               TextColor="#2C3E50"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"/>
                    </HorizontalStackLayout>

                    <!-- Шаг 3 -->
                    <HorizontalStackLayout Spacing="15">
                        <Border Stroke="#9B59B6"
                                StrokeShape="RoundRectangle 50"
                                WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="#9B59B6">
                            <Label Text="3"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Используйте «Прогноз» чтобы узнать, какую оценку нужно получить для желаемого GPA" 
                               FontSize="15"
                               TextColor="#2C3E50"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Часто задаваемые вопросы -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Частые вопросы" 
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#3498DB"/>

                    <!-- Вопрос 1 -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Что такое вес предмета?" 
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"/>
                        <Label Text="Вес (кредиты) показывает важность предмета. Например, курсовая работа может иметь вес 5, а обычная лекция - вес 2." 
                               FontSize="14"
                               TextColor="#7F8C8D"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#ECF0F1"/>

                    <!-- Вопрос 2 -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Можно ли редактировать предметы?" 
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"/>
                        <Label Text="Да! Нажмите на предмет в списке чтобы отредактировать его на странице деталей." 
                               FontSize="14"
                               TextColor="#7F8C8D"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#ECF0F1"/>

                    <!-- Вопрос 3 -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Как интерпретировать результат?" 
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"/>
                        <Label Text="GPA 4.5-5.0 — отлично, 3.5-4.4 — хорошо, 2.0-3.4 — удовлетворительно, ниже 2.0 — нужно подтянуть учебу!" 
                               FontSize="14"
                               TextColor="#7F8C8D"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Контакты -->
            <Border Stroke="#3498DB"
                    StrokeShape="RoundRectangle 15"
                    Padding="20"
                    BackgroundColor="#EBF5FB">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Остались вопросы?" 
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#2980B9"
                           HorizontalOptions="Center"/>
                    <Label Text="Используйте страницу «О программе» для информации о разработчиках" 
                           FontSize="14"
                           TextColor="#2980B9"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>