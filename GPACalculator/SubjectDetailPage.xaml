<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.SubjectDetailPage"
             x:DataType="viewModels:SubjectDetailViewModel"
             BackgroundColor="#F5F5F5"
             Title="Детали предмета">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <Label Text="Редактирование предмета" 
                   FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"
                   TextColor="#2C3E50" Margin="0,10,0,20"/>

            <Border Stroke="#E0E0E0" StrokeShape="RoundRectangle 15" Padding="20" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Название предмета" FontSize="14" TextColor="#7F8C8D"/>
                    <Entry Placeholder="Введите название" Text="{Binding Name, Mode=TwoWay}" BackgroundColor="#FAFAFA"/>

                    <Label Text="Оценка" FontSize="14" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                    <Entry Placeholder="Например, 4.5" Keyboard="Numeric" Text="{Binding Grade, Mode=TwoWay}" BackgroundColor="#FAFAFA"/>

                    <Label Text="Вес предмета" FontSize="14" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                    <Entry Placeholder="Например, 3" Keyboard="Numeric" Text="{Binding Weight, Mode=TwoWay}" BackgroundColor="#FAFAFA"/>

                    <Button Text="Сохранить изменения" 
                            Command="{Binding SaveCommand}"
                            BackgroundColor="#27AE60" TextColor="White" FontAttributes="Bold"
                            FontSize="16" HeightRequest="50" CornerRadius="10" Margin="0,15,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Индикатор успешного сохранения -->
            <Border Stroke="#3498DB" StrokeShape="RoundRectangle 10" Padding="15" BackgroundColor="#EBF5FB" IsVisible="{Binding IsSaved}">
                <Label Text="Изменения успешно сохранены!" FontSize="16" TextColor="#2980B9" FontAttributes="Bold" HorizontalOptions="Center"/>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>