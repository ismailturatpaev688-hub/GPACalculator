<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.SettingsPage"
             x:DataType="viewModels:SettingsViewModel"
             BackgroundColor="#F5F5F5"
             Title="Настройки">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <Label Text="Настройки" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"
                   Margin="0,10,0,20"/>

            <Border Stroke="#E0E0E0" StrokeShape="RoundRectangle 15" Padding="20" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Профиль студента" FontSize="18" FontAttributes="Bold" TextColor="#3498DB" Margin="0,0,0,10"/>

                    <Label Text="Имя студента" FontSize="14" TextColor="#7F8C8D"/>
                    <Entry Placeholder="Введите ваше имя" 
                           Text="{Binding StudentName, Mode=TwoWay}"
                           BackgroundColor="#FAFAFA"/>

                    <Label Text="Целевой GPA" FontSize="14" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                    <Entry Placeholder="Например, 4.5" 
                           Keyboard="Numeric"
                           Text="{Binding TargetGpaText, Mode=TwoWay}"
                           BackgroundColor="#FAFAFA"/>

                    <HorizontalStackLayout Spacing="15" Margin="0,15,0,0">
                        <Button Text="Загрузить" 
                                Command="{Binding LoadSettingsCommand}"
                                BackgroundColor="#95A5A6" TextColor="White" FontAttributes="Bold"
                                FontSize="16" HeightRequest="50" CornerRadius="10" WidthRequest="140"/>

                        <Button Text="Сохранить" 
                                Command="{Binding SaveSettingsCommand}"
                                BackgroundColor="#27AE60" TextColor="White" FontAttributes="Bold"
                                FontSize="16" HeightRequest="50" CornerRadius="10" WidthRequest="140"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Блок для вывода статуса (ошибки или успеха) -->
            <Border Stroke="#3498DB" StrokeShape="RoundRectangle 10" Padding="15" BackgroundColor="#EBF5FB">
                <Label Text="{Binding StatusMessage}" 
                       FontSize="16" TextColor="#2980B9" FontAttributes="Bold"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>