<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GPACalculator.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GPACalculator"
    Title="GPACalculator">

    <!-- Студенты -->
    <ShellContent
        Title="Студенты"
        ContentTemplate="{DataTemplate local:StudentsPage}"
        Route="StudentsPage" />

    <!-- Главная страница -->
    <ShellContent
        Title="Главная"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <!-- Статистика -->
    <ShellContent
        Title="Статистика"
        ContentTemplate="{DataTemplate local:StatisticsPage}"
        Route="StatisticsPage" />

    <!-- Расчет цели -->
    <ShellContent
        Title="Цель"
        ContentTemplate="{DataTemplate local:TargetCalculatorPage}"
        Route="TargetCalculatorPage" />

    <!-- Помощь -->
    <ShellContent
        Title="Помощь"
        ContentTemplate="{DataTemplate local:HelpPage}"
        Route="HelpPage" />

    <!-- О программе -->
    <ShellContent
        Title="О программе"
        ContentTemplate="{DataTemplate local:AboutPage}"
        Route="AboutPage" />

</Shell>