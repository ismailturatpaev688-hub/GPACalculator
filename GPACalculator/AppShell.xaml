<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GPACalculator.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GPACalculator"
    Title="GPACalculator">

    <!-- Главная страница (первая при запуске) -->
    <ShellContent
        Title="Главная"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <!-- Статистика успеваемости -->
    <ShellContent
        Title="Статистика"
        ContentTemplate="{DataTemplate local:StatisticsPage}"
        Route="StatisticsPage" />

    <!-- Расчет целевого GPA (НОВАЯ) -->
    <ShellContent
        Title="Цель"
        ContentTemplate="{DataTemplate local:TargetCalculatorPage}"
        Route="TargetCalculatorPage" />

    <!-- Детали предмета (скрыта из меню, открывается по клику) -->
    <!-- Не добавляем в ShellContent, открывается через навигацию -->

    <!-- Помощь и инструкция (НОВАЯ) -->
    <ShellContent
        Title="Помощь"
        ContentTemplate="{DataTemplate local:HelpPage}"
        Route="HelpPage" />

    <!-- О программе -->
    <ShellContent
        Title="О программе"
        ContentTemplate="{DataTemplate local:AboutPage}"
        Route="AboutPage" />

    <ShellContent
    Title="По предмету"
    ContentTemplate="{DataTemplate local:SingleSubjectCalculatorPage}"
    Route="SingleSubjectCalculatorPage" />

</Shell>
