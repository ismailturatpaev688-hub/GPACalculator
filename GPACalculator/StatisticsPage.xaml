<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.StatisticsPage"
             x:DataType="viewModels:StatisticsViewModel"
             BackgroundColor="#F5F5F5"
             Title="Статистика">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <!-- Заголовок -->
            <Label Text="Статистика успеваемости" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"
                   Margin="0,10,0,20"/>

            <!-- Блок общего среднего балла -->
            <Border Stroke="#27AE60" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20" 
                    BackgroundColor="#EAFAF1">
                <Label Text="{Binding AverageGpaText}" 
                       FontSize="24" 
                       TextColor="#27AE60" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center"/>
            </Border>

            <!-- Блок распределения оценок -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20" 
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Распределение оценок" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#3498DB"/>

                    <!-- Пятерки -->
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Пятерок (5):" 
                               FontSize="16" 
                               TextColor="#27AE60"
                               FontAttributes="Bold"
                               WidthRequest="120"/>
                        <Border Stroke="#27AE60" 
                                StrokeShape="RoundRectangle 8" 
                                Padding="15,5" 
                                BackgroundColor="#EAFAF1">
                            <Label Text="{Binding CountFives}" 
                                   FontSize="18" 
                                   TextColor="#27AE60" 
                                   FontAttributes="Bold"/>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Четверки -->
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Четверок (4):" 
                               FontSize="16" 
                               TextColor="#3498DB"
                               FontAttributes="Bold"
                               WidthRequest="120"/>
                        <Border Stroke="#3498DB" 
                                StrokeShape="RoundRectangle 8" 
                                Padding="15,5" 
                                BackgroundColor="#EBF5FB">
                            <Label Text="{Binding CountFours}" 
                                   FontSize="18" 
                                   TextColor="#3498DB" 
                                   FontAttributes="Bold"/>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Тройки -->
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Троек (3):" 
                               FontSize="16" 
                               TextColor="#F39C12"
                               FontAttributes="Bold"
                               WidthRequest="120"/>
                        <Border Stroke="#F39C12" 
                                StrokeShape="RoundRectangle 8" 
                                Padding="15,5" 
                                BackgroundColor="#FEF9E7">
                            <Label Text="{Binding CountThrees}" 
                                   FontSize="18" 
                                   TextColor="#F39C12" 
                                   FontAttributes="Bold"/>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Двойки -->
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Двоек (2):" 
                               FontSize="16" 
                               TextColor="#E74C3C"
                               FontAttributes="Bold"
                               WidthRequest="120"/>
                        <Border Stroke="#E74C3C" 
                                StrokeShape="RoundRectangle 8" 
                                Padding="15,5" 
                                BackgroundColor="#FADBD8">
                            <Label Text="{Binding CountTwos}" 
                                   FontSize="18" 
                                   TextColor="#E74C3C" 
                                   FontAttributes="Bold"/>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Всего оценок -->
                    <BoxView HeightRequest="1" Color="#ECF0F1" Margin="0,10"/>
                    <Label Text="{Binding TotalGradesText}" 
                           FontSize="16" 
                           TextColor="#7F8C8D"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Средний балл по предметам -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20" 
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Данные по предметам" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#3498DB"/>

                    <CollectionView ItemsSource="{Binding SubjectStatsList}" 
                                    MinimumHeightRequest="100">
                        <CollectionView.EmptyView>
                            <Label Text="Нет предметов для отображения" 
                                   TextColor="#95A5A6" 
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   Margin="0,20"/>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:SubjectStats">
                                <Border Stroke="#ECF0F1"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="15"
                                        Margin="0,5"
                                        BackgroundColor="#FAFAFA">
                                    <Grid ColumnDefinitions="*, Auto, Auto">
                                        <!-- Название предмета -->
                                        <Label Grid.Column="0"
                                               Text="{Binding Name}" 
                                               FontAttributes="Bold" 
                                               FontSize="16"
                                               TextColor="#2C3E50"
                                               VerticalOptions="Center"/>

                                        <!-- Средний балл -->
                                        <Label Grid.Column="1"
                                               Text="{Binding Grade, StringFormat='{0:F1}'}" 
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#27AE60"
                                               VerticalOptions="Center"
                                               WidthRequest="50"
                                               HorizontalTextAlignment="Center"/>

                                        <!-- Вес -->
                                        <Label Grid.Column="2"
                                               Text="{Binding Weight, StringFormat='(вес {0})'}" 
                                               FontSize="14"
                                               TextColor="#7F8C8D"
                                               VerticalOptions="Center"
                                               Margin="10,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Рекомендация -->
            <Border Stroke="#9B59B6"
                    StrokeShape="RoundRectangle 15"
                    Padding="20"
                    BackgroundColor="#F4ECF7">
                <Label Text="{Binding RecommendedGradeText}" 
                       FontSize="16"
                       TextColor="#8E44AD"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"/>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>