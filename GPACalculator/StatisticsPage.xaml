<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.StatisticsPage"
             x:DataType="viewModels:StatisticsViewModel"
             BackgroundColor="#F5F5F5"
             Title="Статистика">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <Label Text="Статистика" 
                   FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"
                   TextColor="#2C3E50" Margin="0,10,0,20"/>

            <Button Text="Обновить статистику" 
                    Command="{Binding LoadStatisticsCommand}"
                    BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold"
                    FontSize="16" HeightRequest="50" CornerRadius="10"/>

            <!-- Блок общих показателей -->
            <Border Stroke="#E0E0E0" StrokeShape="RoundRectangle 15" Padding="20" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Общие показатели" FontSize="18" FontAttributes="Bold" TextColor="#3498DB"/>

                    <Border Stroke="#27AE60" StrokeShape="RoundRectangle 10" Padding="15" BackgroundColor="#EAFAF1">
                        <Label Text="{Binding AverageGpaText}" FontSize="20" TextColor="#27AE60" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </Border>

                    <Border Stroke="#F39C12" StrokeShape="RoundRectangle 10" Padding="15" BackgroundColor="#FEF9E7">
                        <Label Text="{Binding BestSemesterText}" FontSize="18" TextColor="#F39C12" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- График -->
            <Label Text="Прогресс по семестрам" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,10,0,10"/>

            <CollectionView ItemsSource="{Binding ChartItems}" MinimumHeightRequest="100">
                <CollectionView.EmptyView>
                    <Border Stroke="#BDC3C7" StrokeShape="RoundRectangle 10" Padding="30" BackgroundColor="White">
                        <Label Text="Нет данных для отображения графика" TextColor="#7F8C8D" FontSize="16" HorizontalOptions="Center"/>
                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ChartItem">
                        <Border Stroke="#ECF0F1" StrokeShape="RoundRectangle 10" Padding="15" Margin="0,5" BackgroundColor="White">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding Gpa, StringFormat='{0:F2}'}" FontSize="18" FontAttributes="Bold" TextColor="#9B59B6" VerticalOptions="Center"/>
                                </Grid>
                                <!-- Простой и красивый бар-чарт -->
                                <ProgressBar Progress="{Binding Gpa, Converter={StaticResource GpaToProgressConverter}}" 
                                     ProgressColor="#3498DB" 
                                     HeightRequest="20"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>