<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.SingleSubjectCalculatorPage"
             x:DataType="viewModels:SingleSubjectCalculatorViewModel"
             BackgroundColor="#F5F5F5"
             Title="По одному предмету">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <!-- Заголовок -->
            <Label Text="Калькулятор оценок по предмету" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"
                   Margin="0,10,0,20"/>

            <!-- Ввод названия предмета -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Название предмета" 
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#3498DB"/>

                    <Entry Placeholder="Например, Математика" 
                           Text="{Binding SubjectName, Mode=TwoWay}"
                           BackgroundColor="#FAFAFA"/>
                </VerticalStackLayout>
            </Border>

            <!-- Поле веса -->
            <HorizontalStackLayout Spacing="10">
                <Entry Placeholder="Вес (1-5)" 
                       Text="{Binding Weight, Mode=TwoWay}"
                       Keyboard="Numeric" BackgroundColor="#FAFAFA" WidthRequest="90"/>
            </HorizontalStackLayout>

            <!-- Добавление оценок -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Добавление оценок" 
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#3498DB"/>

                    <HorizontalStackLayout Spacing="10">
                        <Entry Placeholder="Оценка (2-5)" 
                               Text="{Binding NewGrade, Mode=TwoWay}"
                               Keyboard="Numeric"
                               BackgroundColor="#FAFAFA"
                               WidthRequest="150"/>

                        <Button Text="Добавить" 
                                Command="{Binding AddGradeCommand}"
                                BackgroundColor="#27AE60"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="45"
                                CornerRadius="8"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Список добавленных оценок -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="White"
                    IsVisible="{Binding Grades.Count, Converter={StaticResource IntToBoolConverter}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Добавленные оценки:" 
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#2C3E50"/>

                    <FlexLayout Wrap="Wrap" 
                                AlignItems="Center"
                                JustifyContent="Start"
                                BindableLayout.ItemsSource="{Binding Grades}">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:GradeEntry">
                                <Border Stroke="#3498DB"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,6"
                                        Margin="5"
                                        BackgroundColor="#EBF5FB">
                                    <Label Text="{Binding DisplayText}" 
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#2980B9"/>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Блок кнопок управления -->
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="15">
                    <Button Text="Рассчитать" Command="{Binding CalculateCommand}"
                            BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold"
                            FontSize="15" HeightRequest="50" CornerRadius="10" WidthRequest="150"/>
                    <Button Text="Очистить" Command="{Binding ClearCommand}"
                            BackgroundColor="#95A5A6" TextColor="White" FontAttributes="Bold"
                            FontSize="15" HeightRequest="50" CornerRadius="10" WidthRequest="150"/>
                </HorizontalStackLayout>

                <!-- Результат -->
                <Border Stroke="#27AE60"
                    StrokeShape="RoundRectangle 15"
                    Padding="25"
                    BackgroundColor="#EAFAF1">
                    <Label Text="{Binding ResultText}" 
                       FontSize="18"
                       TextColor="#27AE60"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"/>
                </Border>
                <!-- Синхронизация с главной страницей и статистикой -->
                <Button Text="Сохранить в общий список" Command="{Binding SaveToMainCommand}"
            BackgroundColor="#27AE60" TextColor="White" FontAttributes="Bold"
            FontSize="15" HeightRequest="50" CornerRadius="10" WidthRequest="315"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>