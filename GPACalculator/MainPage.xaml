<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             x:Class="GPACalculator.MainPage"
             x:DataType="viewModels:MainViewModel">

    <!-- ScrollView нужен, чтобы если экран маленький, можно было прокрутить содержимое -->
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Заголовок -->
            <Label Text="Калькулятор GPA" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <!-- Блок ввода данных - ЗАМЕНИЛИ Frame НА Border -->
            <Border Stroke="LightGray" 
                    StrokeShape="RoundRectangle 10" 
                    Padding="10" 
                    Margin="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Добавить новый предмет:" FontAttributes="Bold"/>

                    <Entry Placeholder="Название (напр. Математика)" 
                           Text="{Binding NewSubjectName}" />

                    <Entry Placeholder="Оценка (2,0 - 5,0)" 
                           Keyboard="Numeric" 
                           Text="{Binding NewSubjectGrade}" />

                    <Entry Placeholder="Вес предмета (напр. 3)" 
                           Keyboard="Numeric" 
                           Text="{Binding NewSubjectWeight}" />

                    <Button Text="Добавить предмет" 
                            Command="{Binding AddSubjectCommand}" 
                            BackgroundColor="Green" 
                            TextColor="White"/>
                </VerticalStackLayout>
            </Border>

            <!-- Блок списка предметов -->
            <Label Text="Ваши предметы:" FontAttributes="Bold" Margin="0,10,0,0"/>

            <!-- CollectionView - список предметов -->
            <CollectionView ItemsSource="{Binding Subjects}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Subject" 
                                  xmlns:models="clr-namespace:GPACalculator.Models">
                        <!-- ЗАМЕНИЛИ Frame НА Border -->
                        <Border Stroke="Gray" 
                                StrokeShape="RoundRectangle 5" 
                                Padding="5" 
                                Margin="0,2">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding Name}" 
                                       FontAttributes="Bold" 
                                       WidthRequest="120"/>
                                <Label Text="{Binding Grade, StringFormat='Оценка: {0}'}" 
                                       WidthRequest="100"/>
                                <Label Text="{Binding Weight, StringFormat='Вес: {0}'}"/>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Блок кнопок расчета -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Рассчитать GPA" 
                        Command="{Binding CalculateGpaCommand}" 
                        BackgroundColor="Blue" 
                        TextColor="White"/>

                <Button Text="Спрогнозировать" 
                        Command="{Binding PredictGradeCommand}" 
                        BackgroundColor="Purple" 
                        TextColor="White"/>
            </HorizontalStackLayout>

            <!-- Блок вывода результатов - ЗАМЕНИЛИ Frame НА Border -->
            <Border Stroke="Blue" 
                    StrokeShape="RoundRectangle 10" 
                    Padding="10" 
                    BackgroundColor="AliceBlue"
                    Margin="0">
                <VerticalStackLayout>
                    <Label Text="{Binding GpaResultText}" 
                           FontSize="18" 
                           TextColor="DarkBlue"/>
                    <Label Text="{Binding PredictionText}" 
                           FontSize="16" 
                           TextColor="DarkMagenta" 
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
