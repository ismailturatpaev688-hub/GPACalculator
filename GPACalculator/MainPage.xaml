<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:GPACalculator.ViewModels"
             xmlns:models="clr-namespace:GPACalculator.Models"
             x:Class="GPACalculator.MainPage"
             x:DataType="viewModels:MainViewModel"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <!-- Заголовок -->
            <Label Text="Калькулятор GPA" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"
                   Margin="0,10,0,20"/>

            <!-- НОВЫЙ БЛОК: Выбор студента -->
            <Border Stroke="#9B59B6" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="#F4ECF7">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Текущий студент" 
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#8E44AD"/>
                    <Picker ItemsSource="{Binding Students}"
                            ItemDisplayBinding="{Binding DisplayText}"
                            SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                            Title="Выберите студента..."
                            BackgroundColor="White"
                            TextColor="#2C3E50"/>
                    <Label Text="Предметы и оценки будут добавлены выбранному студенту."
                           FontSize="12"
                           TextColor="#7F8C8D"/>
                </VerticalStackLayout>
            </Border>

            <!-- Блок ввода данных -->
            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 15" 
                    Padding="20"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Добавить предмет" 
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#3498DB"
                           Margin="0,0,0,10"/>

                    <Entry Placeholder="Название предмета" 
                           Text="{Binding NewSubjectName, Mode=TwoWay}"
                           BackgroundColor="#FAFAFA"
                           Margin="0,0,0,10"/>

                    <Entry Placeholder="Оценка (2,0 - 5,0)" 
                           Keyboard="Numeric" 
                           Text="{Binding NewSubjectGrade, Mode=TwoWay}"
                           BackgroundColor="#FAFAFA"
                           Margin="0,0,0,10"/>

                    <Entry Placeholder="Вес предмета" 
                           Keyboard="Numeric" 
                           Text="{Binding NewSubjectWeight, Mode=TwoWay}"
                           BackgroundColor="#FAFAFA"
                           Margin="0,0,0,10"/>

                    <Button Text="Добавить предмет" 
                            Command="{Binding AddSubjectCommand}"
                            BackgroundColor="#27AE60"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="10"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Блок списка предметов -->
            <Label Text="Предметы студента" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50"
                   Margin="0,10,0,10"/>

            <!-- Счетчик предметов -->
            <Border Stroke="#3498DB"
                    StrokeShape="RoundRectangle 8"
                    Padding="10"
                    BackgroundColor="#EBF5FB"
                    Margin="0,0,0,10">
                <Label Text="{Binding Subjects.Count, StringFormat='Всего предметов: {0}'}" 
                       FontSize="16" 
                       TextColor="#2980B9"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- CollectionView - список предметов -->
            <CollectionView ItemsSource="{Binding Subjects}" 
                            MinimumHeightRequest="100"
                            Margin="0,0,0,15">

                <CollectionView.EmptyView>
                    <Border Stroke="#BDC3C7"
                            StrokeShape="RoundRectangle 10"
                            Padding="30"
                            BackgroundColor="White">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="Список пуст" 
                                   TextColor="#7F8C8D" 
                                   FontSize="30"
                                   HorizontalOptions="Center"
                                   Margin="0,10,0,0"/>
                            <Label Text="Выберите студента и добавьте предмет!" 
                                   TextColor="#95A5A6" 
                                   FontSize="14"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Subject">
                        <Border Stroke="#ECF0F1" StrokeShape="RoundRectangle 10"
                                Padding="15" Margin="0,5" BackgroundColor="White">
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" 
                                       FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Grade, StringFormat='Ср: {0:F2}'}" 
                                       FontSize="16" FontAttributes="Bold" TextColor="#27AE60" VerticalOptions="Center"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding GradesText}" 
                                       FontSize="13" TextColor="#7F8C8D"/>
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding Weight, StringFormat='Вес: {0}'}" 
                                       FontSize="13" TextColor="#3498DB"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Блок кнопок расчета -->
            <HorizontalStackLayout Spacing="15" 
                                   HorizontalOptions="Center"
                                   Margin="0,10,0,15">
                <Button Text="Рассчитать GPA" 
                        Command="{Binding CalculateGpaCommand}"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        HeightRequest="50"
                        CornerRadius="10"
                        WidthRequest="160"/>

                <Button Text="Прогноз" 
                        Command="{Binding PredictGradeCommand}"
                        BackgroundColor="#9B59B6"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        HeightRequest="50"
                        CornerRadius="10"
                        WidthRequest="160"/>
            </HorizontalStackLayout>

            <!-- Блок вывода результатов -->
            <Border Stroke="#3498DB"
                    StrokeShape="RoundRectangle 15"
                    Padding="25"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Результаты"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#2C3E50"
                           HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" 
                             Color="#ECF0F1"
                             Margin="0,5"/>

                    <Label Text="{Binding GpaResultText}" 
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#27AE60"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"/>

                    <Label Text="{Binding PredictionText}" 
                           FontSize="16"
                           TextColor="#8E44AD"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>